# PEERLESS.AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# ── Google Gemini API (required for analysis) ─────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SMART=gemini-2.5-pro

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Host port 5433 avoids collision with any local postgres on the default 5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=peerless
POSTGRES_USER=peerless
POSTGRES_PASSWORD=changeme_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
# Host port 6380 avoids collision with any local redis on the default 6379.
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PATH=./storage
# Max upload size in bytes (default 25 MB)
MAX_UPLOAD_BYTES=26214400

# ── External APIs ─────────────────────────────────────────────────────────────
# Crossref polite pool — required; add your email for better rate limits.
# https://api.crossref.org/swagger-ui/index.html
CROSSREF_MAILTO=researcher@example.com

# PubMed E-utilities API key (optional; 3 rps without, 10 rps with).
# https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# OpenAlex polite pool email (recommended for reviewer matching).
OPENALEX_MAILTO=researcher@example.com

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password
# Base URL for outbound webhook calls from the backend to n8n
N8N_WEBHOOK_BASE=http://localhost:5678
# Shared secret to authenticate webhook requests
N8N_WEBHOOK_SECRET=changeme_webhook_secret

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
# Random secret for signing sessions — must be at least 32 characters.
SECRET_KEY=changeme_random_secret_at_least_32_chars!

# ── Cost controls ─────────────────────────────────────────────────────────────
# Daily LLM spend cap in USD. Analysis returns 503 when exceeded.
MAX_DAILY_LLM_COST_USD=10.0
# Pricing estimates (USD per 1 000 tokens) — update if Google changes pricing.
LLM_PRICING_FAST_PER_1K_TOKENS=0.000075
LLM_PRICING_SMART_PER_1K_TOKENS=0.00125

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_CORS_ORIGINS=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password for the /queue and /admin endpoints (single-password for hackathon).
ADMIN_SHARED_PASSWORD=changeme_admin_password

# ── Feature flags — disabled by default until Phase 2 safety review ──────────
FEATURE_COI_AGENT=false
FEATURE_REVIEWER_MATCHER=false

# ── SMTP (optional — Phase 3 opt-in submitter email) ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Slack (optional — Phase 3 alert webhook) ─────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
