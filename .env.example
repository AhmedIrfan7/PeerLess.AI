# Environment Variables for PEERLESS.AI
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Google Gemini API ──────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=peerless
POSTGRES_USER=peerless
POSTGRES_PASSWORD=changeme_strong_password

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── ChromaDB ───────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=peerless_corpus

# ─── Storage ────────────────────────────────────────────────────────────────
# Local filesystem path for uploaded papers (relative to backend root)
STORAGE_PATH=./storage

# ─── External APIs ──────────────────────────────────────────────────────────
# Crossref Polite Pool: add your email for higher rate limits
# https://api.crossref.org/swagger-ui/index.html
CROSSREF_MAILTO=your_email@example.com

# PubMed E-utilities API key (optional but recommended for higher rate limits)
# https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# arXiv API does not require authentication; no key needed.

# ─── n8n ────────────────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password

# ─── Application ────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=changeme_random_secret_at_least_32_chars

# ─── Feature Flags (Phase 2 agents) ────────────────────────────────────────
# These are disabled by default. Only enable in Phase 2 after safety review.
FEATURE_COI_ENABLED=false
FEATURE_REVIEWER_ENABLED=false

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
